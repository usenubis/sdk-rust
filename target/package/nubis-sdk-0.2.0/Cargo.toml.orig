[package]
name = "nubis-sdk"
version = "0.2.0"
edition = "2021"
license = "MIT"
description = "Official Nubis Rust SDK"
repository = "https://github.com/usenubis/nubis-core"
readme = "README.md"

[lib]
name = "nubis_sdk"
path = "src/lib.rs"

[dependencies]
reqwest = { version = "0.12", default-features = false, features = ["json", "rustls-tls"] }
serde = { version = "1", features = ["derive"] }
serde_json = "1"
thiserror = "1"
percent-encoding = "2"

[workspace]
